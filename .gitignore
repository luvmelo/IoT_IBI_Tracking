# ─── Python ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# ─── Virtualenvs ─────────────────────────────────────────────────────────
.venv/
venv/
env/
# Note: keep uv.lock and pyproject.toml committed for reproducible installs.

# ─── OS / Editors ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Radar captures (large + binary; never commit) ───────────────────────
# Keep the data/ directory itself via data/.gitkeep, but ignore everything
# inside it. Captured .bin files can be 100s of MB; .npz can be 10s of MB.
data/*
!data/.gitkeep
!data/README.md

# Common capture artifacts that might land outside data/ by accident
*.bin
*.npz
adc_data*.bin
adc_data*.npz
pktlogfile.txt
DataCaptureDemo*.log

# Smoke-test scratch outputs
_smoke.*

# ─── Generated plots ─────────────────────────────────────────────────────
# Plots written to data/ are already covered above. Allow plots in docs/.
*.png
*.pdf.tmp
!docs/**/*.png

# ─── Local Claude / OMC state ────────────────────────────────────────────
.omx/
.claude/
.aider*

# ─── Secrets / env files (defensive) ─────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets.json
credentials.json
